# ── FaceGuard Environment Configuration ──────────────────────────────────────

# LLM API (Mistral)
MISTRAL_API_KEY=your_mistral_api_key_here

# Camera feeds (RTSP URLs — use 0 for webcam in demo mode)
CAM_SNCF=rtsp://192.168.1.10:554/stream1
CAM_AIRPORT=rtsp://192.168.1.11:554/stream1
CAM_EVENT=rtsp://192.168.1.12:554/stream1
CAM_BORDER=rtsp://192.168.1.13:554/stream1

# Demo mode: use local video files instead of RTSP
DEMO_MODE=true
DEMO_VIDEO=data/demo/sample_crowd.mp4

# Detection thresholds
DEEPFAKE_THRESHOLD=0.75
WANTED_THRESHOLD=0.92
BEHAVIOR_THRESHOLD=0.80
CROWD_PANIC_DELTA=0.40
ALERT_THREAT_LEVEL=3

# Database
DB_URL=sqlite:///data/faceguard.db

# ChromaDB
CHROMA_PATH=data/chromadb

# Frame extraction
FPS_CAPTURE=5
MAX_FACES_PER_FRAME=20
